{
  "id": "sidebar-section",
  "name": "Sidebar",
  "category": "sidebar",
  "description": "侧边栏信息卡/导航块，适合目录、资料、快捷操作区域，支持深浅色和RTL",
  "version": "1.0.0",
  "thumbnail": "https://via.placeholder.com/280x360/f8fafc/334155?text=Sidebar",
  "layout": {
    "type": "section",
    "width": "custom",
    "fullWidth": false,
    "customWidth": 320,
    "minHeight": 360,
    "height": "auto"
  },
  "grid": {
    "columns": 1,
    "columnsTablet": 1,
    "columnsPhone": 1,
    "gap": 0,
    "minWidth": 280,
    "maxWidth": 420
  },
  "cardStyle": {
    "bg": "#ffffff",
    "bgDark": "#0f172a",
    "text": "#334155",
    "textDark": "#cbd5e1",
    "border": "#e2e8f0",
    "borderDark": "#1e293b",
    "radius": 18,
    "padding": 24,
    "shadow": "0 10px 30px rgba(15,23,42,0.08)"
  },
  "textStyles": {
    "title": { "fontSize": 20, "fontWeight": 700, "color": "#0f172a", "lineHeight": 1.3, "letterSpacing": 0, "textAlign": "left", "textTransform": "none" },
    "subtitle": { "fontSize": 12, "fontWeight": 700, "color": "#6366f1", "lineHeight": 1.4, "letterSpacing": 0.5, "textAlign": "left", "textTransform": "uppercase" },
    "description": { "fontSize": 14, "fontWeight": 400, "color": "#64748b", "lineHeight": 1.7, "letterSpacing": 0, "textAlign": "left", "textTransform": "none" },
    "button": { "fontSize": 14, "fontWeight": 700, "color": "#ffffff", "lineHeight": 1.4, "letterSpacing": 0, "textAlign": "center", "textTransform": "none" }
  },
  "features": { "darkMode": true, "rtl": true, "responsive": true, "shadow": true },
  "animation": { "enabled": false, "hover": { "cardLift": false, "liftDistance": 0, "cardShadow": false, "shadowIntensity": 0, "imageZoom": false, "imageScale": 1, "buttonColorChange": false, "buttonHoverColor": "" }, "entry": { "enabled": false, "type": "none", "duration": 0, "delay": 0, "stagger": false } },
  "template": {
    "html": "<aside class=\"sidebar-card\">\n  <div class=\"sidebar-top\">\n    <span class=\"sidebar-kicker\">{{subtitle}}</span>\n    <h3 class=\"sidebar-title\">{{name}}</h3>\n    <p class=\"sidebar-desc\">{{description}}</p>\n  </div>\n  <ul class=\"sidebar-menu\">\n    <li><a href=\"#\">{{item1}}</a></li>\n    <li><a href=\"#\">{{item2}}</a></li>\n    <li><a href=\"#\">{{item3}}</a></li>\n    <li><a href=\"#\">{{item4}}</a></li>\n  </ul>\n  <a class=\"sidebar-btn\" href=\"{{link}}\">{{button_text}}</a>\n</aside>",
    "css": ".sidebar-card{background:var(--card-bg,#fff);border:1px solid var(--card-border,#e2e8f0);border-radius:var(--card-radius,18px);padding:var(--card-padding,24px);box-shadow:var(--card-shadow,0 10px 30px rgba(15,23,42,.08));max-width:420px}.sidebar-kicker{font-size:var(--subtitle-font-size,12px);font-weight:700;color:var(--subtitle-color,#6366f1);text-transform:uppercase;letter-spacing:.5px}.sidebar-title{font-size:var(--title-font-size,20px);font-weight:var(--title-font-weight,700);color:var(--title-color,#0f172a);margin:8px 0}.sidebar-desc{font-size:var(--description-font-size,14px);color:var(--description-color,#64748b);line-height:1.7;margin:0 0 16px}.sidebar-menu{list-style:none;padding:0;margin:0 0 18px;display:flex;flex-direction:column;gap:8px}.sidebar-menu a{display:block;padding:10px 12px;border-radius:10px;background:#f8fafc;color:#334155;text-decoration:none;font-weight:500}.sidebar-menu a:hover{background:#eef2ff;color:#4338ca}.sidebar-btn{display:block;text-align:center;padding:12px 18px;border-radius:12px;background:#7c3aed;color:#fff;text-decoration:none;font-weight:700}.dark .sidebar-card,[data-theme=\"dark\"] .sidebar-card{background:#0f172a;border-color:#1e293b}.dark .sidebar-title,[data-theme=\"dark\"] .sidebar-title{color:#e2e8f0}.dark .sidebar-desc,[data-theme=\"dark\"] .sidebar-desc{color:#94a3b8}.dark .sidebar-menu a,[data-theme=\"dark\"] .sidebar-menu a{background:#111827;color:#cbd5e1}[dir=\"rtl\"] .sidebar-card{text-align:right}"
  },
  "fields": {
    "subtitle": { "required": false, "default": "Resources" },
    "name": { "required": true, "default": "Quick Navigation" },
    "description": { "required": false, "default": "Use this sidebar block for secondary navigation, docs, or support links." },
    "item1": { "required": false, "default": "Overview" },
    "item2": { "required": false, "default": "Components" },
    "item3": { "required": false, "default": "Templates" },
    "item4": { "required": false, "default": "Support" },
    "button_text": { "required": false, "default": "Open Docs" },
    "link": { "required": false, "default": "#" }
  },
  "dataMapping": {
    "subtitle": ["subtitle", "tag", "副标题"],
    "name": ["name", "title", "标题"],
    "description": ["description", "desc", "描述"],
    "button_text": ["button_text", "cta", "按钮"]
  }
}
